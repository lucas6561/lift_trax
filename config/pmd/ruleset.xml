<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="lift-trax-static-analysis"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="
            http://pmd.sourceforge.net/ruleset/2.0.0
            https://pmd.github.io/pmd-7.0.0/ruleset_xml_schema.xsd">

    <description>
        PMD rules focused on correctness, security, and maintainability.
        Avoids low-value stylistic churn.
    </description>

    <rule ref="category/java/errorprone.xml">
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="LiteralsFirstInComparisons"/>
    </rule>

    <rule ref="category/java/security.xml">
        <exclude name="AvoidAccessibilityAlteration"/>
    </rule>

    <rule ref="category/java/bestpractices.xml">
        <exclude name="SystemPrintln"/>
        <exclude name="ImplicitFunctionalInterface"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
    </rule>

    <rule ref="category/java/codestyle.xml/ClassNamingConventions"/>
    <rule ref="category/java/codestyle.xml/MethodNamingConventions"/>
    <rule ref="category/java/codestyle.xml/FieldNamingConventions"/>
    <rule ref="category/java/codestyle.xml/UnnecessaryImport"/>

    <rule ref="category/java/design.xml/CyclomaticComplexity">
        <properties>
            <property name="classReportLevel" value="250"/>
            <property name="methodReportLevel" value="30"/>
        </properties>
    </rule>
    <!-- PMD 7 removed ExcessiveMethodLength from design rules; using closest size-oriented surrogate. -->
    <rule ref="category/java/design.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="15"/>
        </properties>
    </rule>

    <rule ref="category/java/design.xml/NPathComplexity">
        <properties>
            <property name="reportLevel" value="100000000"/>
        </properties>
    </rule>

</ruleset>
