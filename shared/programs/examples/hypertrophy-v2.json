  "progressionRules": {
    "primaryHypertrophy": {
      "type": "fixed",
      "pattern": [
        {
          "percent": 70,
          "rpe": 7.5
        }
      ]
    },
    "secondaryHypertrophy": {
      "type": "fixed",
      "pattern": [
        {
          "percent": 65,
          "rpe": 7
        }
      ]
    },
    "accessoryHypertrophy": {
      "type": "fixed",
      "pattern": [
        {
          "rpe": 8
        }
      ]
    }
  },
  "substitutionRules": {
    "samePrimaryPattern": {
      "description": "Main lift substitutions should stay in the same lower or upper primary pattern.",
      "allowedPoolRefs": [
        "lowerPrimaryRotation",
        "upperPrimaryRotation"
      ],
      "allowCoachChoice": true
    },
    "sameAccessoryMuscle": {
      "description": "Accessory substitutions should train the same listed muscle.",
      "allowedPoolRefs": [
        "hamstrings",
        "quads",
        "core",
        "chest",
        "lats",
        "triceps"
      ],
      "allowCoachChoice": true
    }
  },
