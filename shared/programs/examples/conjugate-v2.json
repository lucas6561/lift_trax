  "progressionRules": {
    "maxEffortTopSingle": {
      "type": "fixed",
      "pattern": [
        {
          "percent": 95,
          "instruction": "Target 95% of max; go higher only if it feels great."
        }
      ]
    },
    "backoffTodayOneRepMax": {
      "type": "fixed",
      "pattern": [
        {
          "percentMin": 80,
          "percentMax": 85,
          "instruction": "Use 80-85% of today's top single."
        }
      ]
    },
    "supplementalEightyFive": {
      "type": "fixed",
      "pattern": [
        {
          "percent": 85
        }
      ]
    },
    "dynamicChainsWave": {
      "type": "wave_percent",
      "cycleWeeks": 6,
      "pattern": [
        {
          "week": 1,
          "percent": 60,
          "accommodatingResistance": "STRAIGHT"
        },
        {
          "week": 2,
          "percent": 65,
          "accommodatingResistance": "STRAIGHT"
        },
        {
          "week": 3,
          "percent": 70,
          "accommodatingResistance": "STRAIGHT"
        },
        {
          "week": 4,
          "percent": 50,
          "accommodatingResistance": "CHAINS"
        },
        {
          "week": 5,
          "percent": 55,
          "accommodatingResistance": "CHAINS"
        },
        {
          "week": 6,
          "percent": 60,
          "accommodatingResistance": "CHAINS"
        }
      ]
    },
    "dynamicBandsWave": {
      "type": "wave_percent",
      "cycleWeeks": 6,
      "pattern": [
        {
          "week": 1,
          "percent": 60,
          "accommodatingResistance": "STRAIGHT"
        },
        {
          "week": 2,
          "percent": 65,
          "accommodatingResistance": "STRAIGHT"
        },
        {
          "week": 3,
          "percent": 70,
          "accommodatingResistance": "STRAIGHT"
        },
        {
          "week": 4,
          "percent": 50,
          "accommodatingResistance": "BANDS"
        },
        {
          "week": 5,
          "percent": 55,
          "accommodatingResistance": "BANDS"
        },
        {
          "week": 6,
          "percent": 60,
          "accommodatingResistance": "BANDS"
        }
      ]
    }
  },
  "substitutionRules": {
    "mainLiftSamePattern": {
      "description": "Swap a main lift only for another lift from the same pattern family unless a coach overrides it.",
      "allowedPoolRefs": [
        "lowerMaxEffort",
        "upperMaxEffort",
        "dynamicSquat",
        "dynamicDeadlift",
        "dynamicBench",
        "dynamicOverhead"
      ],
      "allowCoachChoice": true
    },
    "accessoryNoDuplicateCableOrDb": {
      "description": "Accessory circuits should avoid duplicate cable or dumbbell-like movements in the same circuit.",
      "allowedPoolRefs": [
        "hamstrings",
        "quads",
        "calves",
        "core",
        "lats",
        "triceps",
        "upperThirdAccessory",
        "biceps"
      ],
      "avoidDuplicateTags": [
        "cable",
        "dumbbell"
      ],
      "allowCoachChoice": true
    }
  },
