    "author": "LiftTrax",
    "createdBy": "app",
    "tags": [
      "conjugate",
      "strength",
      "dynamic-effort"
    ],
    "defaultUnits": "lb",
    "durationWeeks": 6,
    "daysPerWeek": 4,
    "notes": "The max effort and dynamic lift pools can be coach-selected or app-selected before validation."
  },
